{
  "manifest_version": 3,
  "name": "Açougue Imagens — Pesquisa Profissional",
  "version": "1.1.0",
  "description": "Side Panel para pesquisa manual de imagens de produtos de açougue no Google Imagens.",
  "permissions": ["storage", "tabs", "sidePanel", "activeTab"],
  "host_permissions": ["http://localhost:3000/*"],
  "content_scripts": [
    {
      "matches": ["*://www.google.com/search*", "*://www.google.com.br/search*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Açougue Imagens — Pesquisa Profissional"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

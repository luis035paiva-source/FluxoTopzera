{
  "manifest_version": 3,
  "name": "Peixaria Imagens — Pesquisa Profissional",
  "version": "1.0.0",
  "description": "Side Panel para pesquisa manual de imagens de produtos de peixaria no Google Imagens.",
  "permissions": ["storage", "tabs", "sidePanel"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Peixaria Imagens — Pesquisa Profissional"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
